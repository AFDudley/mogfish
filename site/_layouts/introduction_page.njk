---
layout: base.njk
---

<section class="guide-layout">
  <details class="guide-toc" open>
    <summary>Contents</summary>
    <a class="guide-toc-top" href="#introduction">Back to top</a>
    <ol class="guide-toc-list">
      {% for item in introductionToc %}
        {% if not (loop.first and item.level == 1 and item.title == page.title) %}
          <li class="guide-toc-item guide-toc-level-{{ item.level }}">
            <a href="#{{ item.id }}">{{ item.title }}</a>
          </li>
        {% endif %}
      {% endfor %}
    </ol>
  </details>
  <article id="introduction" class="guide-wrap">
    {{ content | safe }}
  </article>
</section>
