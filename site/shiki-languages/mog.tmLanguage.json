{
  "name": "Mog",
  "scopeName": "source.mog",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#functions" },
    { "include": "#operators" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.block.mog",
          "begin": "\/\*",
          "end": "\*\/"
        },
        {
          "name": "comment.line.double-slash.mog",
          "match": "\/\/.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.mog",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.mog",
              "match": "\\\\(?:x[0-9A-Fa-f]{2}|u\{[0-9A-Fa-f]{1,6}\}|u[0-9A-Fa-f]{4}|[abfnrtv\\\"'])"
            },
            {
              "name": "meta.interpolation.mog",
              "match": "\\{[^{}]*\\}"
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.mog",
          "match": "\\b(await|async|fn|for|while|if|else|match|return|break|continue|defer|true|false|nil|none|ok|err|requires|optional|throws|try|catch|finally|import|from|export|in)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.mog",
          "match": "\\b(int|i32|i64|u32|u64|f16|bf16|f32|f64|float|string|bool|byte|bytes|void|Task|Result|Error|tensor)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.mog",
          "match": "\\b(null|true|false|none|ok|err)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.mog",
          "match": "\\b(0x[0-9A-Fa-f]+|0b[01]+|0o[0-7]+|[0-9]+(?:\\.[0-9]+)?(?:[eE][+-]?[0-9]+)?|\\.[0-9]+(?:[eE][+-]?[0-9]+)?)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "entity.name.function.mog",
          "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.mog",
          "match": "(\\+\\+|--|=>|==|!=|<=|>=|\\|\\||&&|:=|->|[+\\-*/%<>]=?|[=.,:;(){}\\[\\]])"
        }
      ]
    }
  },
  "fileTypes": ["mog"]
}
